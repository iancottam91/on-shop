      "updated": 1770974844616,
      "link": null,
      "locked": false,
      "text": "Web Shop Application System Design ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Web Shop Application System Design ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dpXBHX6y1xhKZrLEMXRkJ",
      "type": "text",
      "x": 1409.897744893216,
      "y": -543.5642167212643,
      "width": 563.2796020507812,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b8H",
      "roundness": null,
      "seed": 1619659448,
      "version": 607,
      "versionNonce": 211267768,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1770975947490,
      "link": null,
      "locked": false,
      "text": "Non Function Requirements:\n\nUsers:\n- $10 mil rev per month\n- Average order = $200\n- 10mil/200/30 = 1666\n- Handle 1500-2000 orders per day\n- Assume 1/10 browsers purchase = 15000-20000 viewers\nper day\n- 10-15 views per minute",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non Function Requirements:\n\nUsers:\n- $10 mil rev per month\n- Average order = $200\n- 10mil/200/30 = 1666\n- Handle 1500-2000 orders per day\n- Assume 1/10 browsers purchase = 15000-20000 viewers\nper day\n- 10-15 views per minute",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "m1Ubr9vKeQzFLg0o8EOy1",
      "type": "text",
      "x": 1404.3550862920724,
      "y": -113.39291852772044,
      "width": 459.75970458984375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b8I",
      "roundness": null,
      "seed": 856430280,
      "version": 498,
      "versionNonce": 1545633208,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1770975952941,
      "link": null,
      "locked": false,
      "text": "Key Problems with current system to address:\n\n1) Slow page load\n\n2) Site becomes unresponsive due to DB load\nduring traffic spikes\n\n3) The 'job queue' gets flooded with jobs that\nit cannot execute",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Key Problems with current system to address:\n\n1) Slow page load\n\n2) Site becomes unresponsive due to DB load\nduring traffic spikes\n\n3) The 'job queue' gets flooded with jobs that\nit cannot execute",
      "autoResize": true,
      "lineHeight": 1.25
    },
