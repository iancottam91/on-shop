    {
      "id": "g_bwWNWLuEL2QaEXOXrQS",
      "type": "text",
      "x": 5053.78518493794,
      "y": -813.0447739577621,
      "width": 756.2993774414062,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
