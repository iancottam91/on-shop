    },
    {
      "id": "kEoPEbRrvMO2ZPB6nngR0",
      "type": "text",
      "x": 3040.7908216270034,
      "y": 1000.2723936013052,
      "width": 550.57958984375,
      "height": 50,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBh",
      "roundness": null,
      "seed": 1557167800,
      "version": 588,
      "versionNonce": 1499387832,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770993064388,
      "link": null,
      "locked": false,
      "text": "Problem 3:\n- Ensure all post order work is done async using queues ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problem 3:\n- Ensure all post order work is done async using queues ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "SLThPZQOeLJp863qow4b8",
      "type": "text",
      "x": 3047.143848968082,
      "y": 541.8591001359441,
      "width": 1295.5592041015625,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBi",
      "roundness": null,
      "seed": 147843016,
      "version": 560,
      "versionNonce": 1709497272,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1770979536271,
      "link": null,
      "locked": false,
      "text": "Design Priorities:\n\n1) Protect Inventory DB for user facing traffic as much as possible\n\n2) Use Federation to handle scale: Separate out different data entites into more granular stores that can scale to their own needs\n\n2) Ensure anything that can be done async is done async",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Design Priorities:\n\n1) Protect Inventory DB for user facing traffic as much as possible\n\n2) Use Federation to handle scale: Separate out different data entites into more granular stores that can scale to their own needs\n\n2) Ensure anything that can be done async is done async",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "VKDFeA_iHdFzixtxlEE7v",
      "type": "text",
      "x": 6154.629155173532,
      "y": -1070.645757856454,
      "width": 292.4998474121094,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBj",
      "roundness": null,
      "seed": 2117304264,
      "version": 189,
      "versionNonce": 139861448,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770978637347,
      "link": null,
      "locked": false,
      "text": "How to get there from Heroku",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How to get there from Heroku",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-f8leJKgwGls9USwT3DkK",
      "type": "line",
      "x": 5883.7099003835265,
      "y": -1069.167198517488,
      "width": 12.804444792030154,
      "height": 1546.7717856028437,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBk",
      "roundness": {
        "type": 2
      },
      "seed": 637136328,
      "version": 239,
      "versionNonce": 2006845384,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1770981582077,
