      "boundElements": null,
      "updated": 1770993053915,
      "link": null,
      "locked": false,
      "text": "Problem 1 & 2:\n- Ensure browse requests do not go direct to Inventory DB\n- We've implemented a read optimised DB for queries\n- We'll have a load balancer and horizontally scale our front end app\n- We'll can consider serving front end from CDNs",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problem 1 & 2:\n- Ensure browse requests do not go direct to Inventory DB\n- We've implemented a read optimised DB for queries\n- We'll have a load balancer and horizontally scale our front end app\n- We'll can consider serving front end from CDNs",
      "autoResize": true,
      "lineHeight": 1.25
    },
