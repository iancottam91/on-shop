      "seed": 1492984248,
      "version": 574,
      "versionNonce": 2014951624,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1770981097327,
      "link": null,
      "locked": false,
      "text": "Assumed Key Functional Requirements in scope:\n \n- Browse Stock\n    - by categories\n    - search (out of scope due to timelines)\n\n- Purchase Stock\n    - Checkout journey\n    - Payment integration\n\n- Stock Management\n    - Update stock inventory\n\n- Post Order Functionality:\n    - Order Update Notifications\n    - Returns",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Assumed Key Functional Requirements in scope:\n \n- Browse Stock\n    - by categories\n    - search (out of scope due to timelines)\n\n- Purchase Stock\n    - Checkout journey\n    - Payment integration\n\n- Stock Management\n    - Update stock inventory\n\n- Post Order Functionality:\n    - Order Update Notifications\n    - Returns",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "C-mKiU_K9HIgxynlLd18t",
      "type": "text",
      "x": 1409.4129944525234,
      "y": -1019.2896746996397,
      "width": 360.5797119140625,
      "height": 25,
      "angle": 0,
